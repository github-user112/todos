{
  "name": "vue-calendar-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev-api": "wrangler dev --port 8787",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node test/repeatFunctionTest.js",
    "db:local": "powershell -File deploy.ps1 db:local",
    "db:remote": "powershell -File deploy.ps1 db:remote",
    "migrate:local": "powershell -File deploy.ps1 migrate:local",
    "migrate:remote": "powershell -File deploy.ps1 migrate:remote",
    "deploy": "powershell -File deploy.ps1 deploy",
    "deploy:full": "powershell -File deploy.ps1 deploy:full"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "vite": "^8.0.10",
    "vue": "^3.5.26",
    "wrangler": "^4.56.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "holiday-calendar": "^1.3.3",
    "lunar-javascript": "^1.7.7",
    "naive-ui": "^2.43.2",
    "vue-router": "^5.0.7"
  }
}
